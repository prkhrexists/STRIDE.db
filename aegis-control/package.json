{
  "name": "aegis-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run pi-proxy\" \"npm run mavlink\" \"npm run usb\" \"next dev\"",
    "pi-proxy": "node server/piProxy.js",
    "mavlink": "node server/mavlinkService.js",
    "usb": "node server/usbDroneService.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:gcs": "cross-env MAV_CONNECTION=udp next dev",
    "test:mavlink": "node scripts/test-mavlink-connection.js",
    "test:picam": "node scripts/test-picam-stream.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/three": "^0.184.1",
    "adm-zip": "^0.5.17",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^4.0.0",
    "jimp": "^1.6.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "node-abort-controller": "^3.1.1",
    "node-mavlink": "^2.3.0",
    "node-ssh": "^13.2.1",
    "onnxruntime-node": "^1.26.0",
    "openai": "^6.37.0",
    "pdfkit": "^0.18.0",
    "piexifjs": "^1.0.6",
    "ping": "^1.0.0",
    "puppeteer": "^25.0.2",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "serialport": "^13.0.0",
    "sharp": "^0.34.5",
    "ssim.js": "^3.5.0",
    "three": "^0.184.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "typescript": "^5"
  }
